# Published payload is AOT-only (bin/ + dist/). Keep installs free of
# sources, tests, docs, tooling, and local agent adapters.

# Sources (bundled into dist/ by prepack build)
src/
extensions/

# Tests / fixtures
**/*.test.ts
**/test/**

# Dev / pack-only (prepack runs from source before this filter)
scripts/
install.sh
test.sh
tsconfig.json
vitest.config.*
.npmrc

# Docs live on GitHub
docs/
*.md
!README.md
!LICENSE

# Sourcemaps stay local; not needed under node_modules
**/*.map

# Local agent / IDE adapters (never ship)
.trellis/
.cursor/
.claude/
.codex/
.gitnexus/
.grok/
.agents/
.vscode/
.idea/
coverage/
node_modules/
*.tgz
archive/
