#!/usr/bin/env bash
# Resolve this script through npm global symlinks, then run the TS entry with Node strip-types.
set -euo pipefail
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  LINK="$(readlink "$SOURCE")"
  [[ "$LINK" != /* ]] && SOURCE="$DIR/$LINK" || SOURCE="$LINK"
done
ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
exec node --experimental-strip-types "$ROOT/src/cli/index.ts" "$@"
