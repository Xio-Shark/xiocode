#!/usr/bin/env bash
# Prefer AOT split bundle (dist/xio.js); fall back to TypeScript strip-types for local dev.
set -euo pipefail
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  LINK="$(readlink "$SOURCE")"
  [[ "$LINK" != /* ]] && SOURCE="$DIR/$LINK" || SOURCE="$LINK"
done
ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
if [ -f "$ROOT/dist/xio.js" ]; then
  exec node "$ROOT/dist/xio.js" "$@"
fi
# Legacy single-file name from earlier builds
if [ -f "$ROOT/dist/xio.mjs" ]; then
  exec node "$ROOT/dist/xio.mjs" "$@"
fi
exec node --experimental-strip-types "$ROOT/src/cli/entry.ts" "$@"
