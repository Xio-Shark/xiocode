#!/usr/bin/env bash
set -euo pipefail
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  LINK="$(readlink "$SOURCE")"
  [[ "$LINK" != /* ]] && SOURCE="$DIR/$LINK" || SOURCE="$LINK"
done
ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
if [ -f "$ROOT/dist/xio-improve.js" ]; then
  exec node "$ROOT/dist/xio-improve.js" "$@"
fi
if [ -f "$ROOT/dist/xio-improve.mjs" ]; then
  exec node "$ROOT/dist/xio-improve.mjs" "$@"
fi
exec node --experimental-strip-types "$ROOT/src/cli/improve-entry.ts" "$@"
